# ─── Единственный файл, который нужно отредактировать при деплое ───
# Скопируйте: cp .env.example .env  и впишите свои значения.

# API-ключ DeepSeek — получить на https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-ВСТАВЬТЕ_СВОЙ_КЛЮЧ

# Логин и пароль для входа в веб-интерфейс (HTTP basic auth).
# nginx сам сгенерирует .htpasswd из этих значений при старте —
# отдельная команда htpasswd и пакет apache2-utils больше не нужны.
WEB_LOGIN=admin
WEB_PASSWORD=смените_этот_пароль

# Модель Whisper:
#   small   — быстро (~1.5-2.5ч на час видео), RAM ~1.5 ГБ  ← по умолчанию
#   medium  — медленно (~4-6ч), RAM ~3 ГБ
#   large-v3— очень медленно, требуется VPS с 8+ ГБ RAM
WHISPER_MODEL=small

# Язык транскрибации
LANGUAGE=ru

# Real-Time Factor для оценки времени обработки
# Калибруйте под свой сервер по логам (factor=X.XXx)
RTF=2.0
