# ─── Единственный файл, который нужно отредактировать при деплое ───
# Скопируйте: cp .env.example .env  и впишите свои значения.

# API-ключ DeepSeek — получить на https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-ВСТАВЬТЕ_СВОЙ_КЛЮЧ

# Логин и пароль администратора для входа в веб-интерфейс (HTTP basic auth).
# nginx сам сгенерирует .htpasswd из этих значений при старте —
# отдельная команда htpasswd и пакет apache2-utils больше не нужны.
WEB_LOGIN=admin
WEB_PASSWORD=смените_этот_пароль

# Пользователи команды tldw1..tldw4 — у каждого свой вход и своя (изолированная)
# история обработок. Логины фиксированы (tldw1..tldw4), задайте им пароли ниже.
# Пустой пароль = пользователь не создаётся. Сгенерировать пароль:
#   python3 -c "import secrets,string; a=string.ascii_letters+string.digits; print(''.join(secrets.choice(a) for _ in range(16)))"
TLDW1_PASSWORD=
TLDW2_PASSWORD=
TLDW3_PASSWORD=
TLDW4_PASSWORD=

# Модель Whisper:
#   small   — быстро (~1.5-2.5ч на час видео), RAM ~1.5 ГБ  ← по умолчанию
#   medium  — медленно (~4-6ч), RAM ~3 ГБ
#   large-v3— очень медленно, требуется VPS с 8+ ГБ RAM
WHISPER_MODEL=small

# Язык транскрибации
LANGUAGE=ru

# Потоки CPU для faster-whisper — ставьте по числу ядер VPS (или на 1-2 больше)
CPU_THREADS=4

# Real-Time Factor для оценки времени обработки
# Калибруйте под свой сервер по логам (factor=X.XXx)
RTF=2.0
